# Sao chép thành .env trên server (/opt/ikp/.env). Không commit file .env thật.

POSTGRES_USER=ikp
POSTGRES_PASSWORD=thay-bang-mat-khau-manh
POSTGRES_DB=ikp

# Trùng khớp mật khẩu Postgres (host = tên service trong compose: postgres)
DATABASE_URL=postgresql://ikp:thay-bang-mat-khau-manh@postgres:5432/ikp?schema=public

# URL API công khai mà trình duyệt gọi được (ảnh hưởng build Next — xem GitLab CI variable NEXT_PUBLIC_API_URL)
# NEXT_PUBLIC_API_URL=https://api.example.com
