# ===============================
# DOCKER (PostgreSQL)
# ===============================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ikp_db
POSTGRES_PORT=5432

# ===============================
# APPLICATION
# ===============================
HOST=0.0.0.0
PORT=5000
FRONTEND_PORT=3000
