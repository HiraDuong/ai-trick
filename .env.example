JWT_SECRET=local-dev-secret-12345
JWT_EXPIRES_IN=7d
API_BASE_URL=http://localhost:5000/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api
CORS_ORIGIN=http://localhost:3000